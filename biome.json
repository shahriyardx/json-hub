{
	"$schema": "https://biomejs.dev/schemas/1.8.2/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"noSvgWithoutTitle": "off",
				"useValidAnchor": "off",
				"useButtonType": "warn",
				"noAutofocus": "info"
			},
			"style": {
				"useSelfClosingElements": "off",
				"noUnusedTemplateLiteral": "off"
			},
			"suspicious": {
				"noArrayIndexKey": "off",
				"noExplicitAny": "info"
			}
		}
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded"
		}
	},
	"files": {
		"ignore": [".next", ".vscode", "node_modules"]
	}
}
